# Nuxt SDK Playground - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================
# Asgardeo Configuration
# ============================================

# Base URL of your Asgardeo organization
# Format: https://api.asgardeo.io/t/{organization_name}
NUXT_PUBLIC_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/your_organization

# OAuth2 Client ID from your Asgardeo application
NUXT_PUBLIC_ASGARDEO_CLIENT_ID=your_client_id_here

# Client Secret (keep this secure, never commit to git)
ASGARDEO_CLIENT_SECRET=your_client_secret_here

# ============================================
# Session Configuration (Server-side only)
# ============================================

# Session signing secret - must be at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ASGARDEO_SESSION_SECRET=your_session_secret_here_min_32_chars

# ============================================
# Optional: Callback URLs
# ============================================

# Redirect URI after successful authentication (optional, defaults to current app URL)
# ASGARDEO_CALLBACK_URL=http://localhost:3000/callback

# Logout redirect URI (optional)
# ASGARDEO_LOGOUT_URL=http://localhost:3000

# ============================================
# Development Server
# ============================================

# Nuxt dev server port (optional)
# NUXT_PORT=3000

# Nuxt dev server host (optional)
# NUXT_HOST=localhost
