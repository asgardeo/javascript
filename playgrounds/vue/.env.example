# Vue SDK Playground - Environment Configuration Example
# Copy this file to .env.local and fill in your actual values

# ============================================
# Asgardeo Configuration
# ============================================

# Base URL of your Asgardeo organization
# Format: https://api.asgardeo.io/t/{organization_name}
VITE_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/your_organization

# OAuth2 Client ID from your Asgardeo application
VITE_ASGARDEO_CLIENT_ID=your_client_id_here

# ============================================
# Redirect URLs
# ============================================

# Redirect URI after successful authentication
# Should match the callback URL registered in your Asgardeo application
VITE_ASGARDEO_AFTER_SIGN_IN_URL=http://localhost:5173

# Redirect URI after successful logout
VITE_ASGARDEO_AFTER_SIGN_OUT_URL=http://localhost:5173

# ============================================
# Optional: Additional Configuration
# ============================================

# Application name (optional)
# VITE_APP_NAME=Vue SDK Playground

# Asgardeo API scope (optional, defaults to openid profile)
# VITE_ASGARDEO_SCOPE=openid profile email

# Session timeout in milliseconds (optional)
# VITE_SESSION_TIMEOUT=1800000

# ============================================
# Development Server (Vite)
# ============================================

# Vite server port (optional)
# VITE_PORT=5173

# Vite server host (optional)
# VITE_HOST=localhost
