# Playground environment variables
# Copy this file to .env and fill in your Asgardeo application details.
# Do NOT commit .env to source control.

# Public (client-visible) — read automatically by @asgardeo/nuxt
NUXT_PUBLIC_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<your-org>
NUXT_PUBLIC_ASGARDEO_CLIENT_ID=<your-client-id>

# Optional: override redirect targets (defaults to '/')
# NUXT_PUBLIC_ASGARDEO_AFTER_SIGN_IN_URL=http://localhost:3000
# NUXT_PUBLIC_ASGARDEO_AFTER_SIGN_OUT_URL=http://localhost:3000

# Private (server-only) — never exposed to the browser
ASGARDEO_CLIENT_SECRET=<your-client-secret>
# Generate with: openssl rand -base64 32
ASGARDEO_SESSION_SECRET=<at-least-32-char-random-secret>
