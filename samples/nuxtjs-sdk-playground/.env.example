# Playground environment variables
# Copy this file to .env and fill in your values

NUXT_PUBLIC_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<org>
NUXT_PUBLIC_ASGARDEO_CLIENT_ID=<client-id>
ASGARDEO_CLIENT_SECRET=<client-secret>
# Generate with: openssl rand -base64 32
ASGARDEO_SESSION_SECRET=<32+ random chars>
